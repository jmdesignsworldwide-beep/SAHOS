# ---------------------------------------------------------------------------
# SAHOS environment variables.
# Copy to `.env.local` for local dev, and set the same keys in Vercel.
# NEVER commit real values. Secrets marked (server-only) must NEVER be exposed
# to the client — do not prefix them with NEXT_PUBLIC_. (spec §8.1)
# ---------------------------------------------------------------------------

# --- Supabase ---
# Public, safe to expose (anon key is RLS-gated):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# server-only — full DB bypass, NEVER ship to the browser:
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# Public publishable key (safe on client):
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# server-only secret + webhook signing secret:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
